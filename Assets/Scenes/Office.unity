--- !u!114 &9000000000100000001
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 519420028}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f0e1d2c3b4a5968778695012a3b4c5d6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  introDialogue:
  - name: ' '
    text: "\uFF08\u4E0D\u662F\u5427\uFF0C\u6211\u600E\u4E48\u53C8\u56DE\u5DE5\u4F4D\u4E86\uFF01\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\uFF08\u88AB\u56FA\u5B9A\u62F4\u5728\u5DE5\u4F4D\u4E0A\u4E86\u5417\u2026\u2026\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\uFF08\u5148\u770B\u770B\u7535\u8111\u4E0A\u5DE8\u4FE1\u53C8\u6765\u4EC0\u4E48\u6D88\u606F\u4E86\u5427\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\uFF08\u521A\u521A\u600E\u4E48\u597D\u50CF\u542C\u5230\u6309E\u53EF\u4EE5\u548C\u7269\u4F53\u4EA4\u4E92\u2026\u2026\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  returnDialogue:
  - name: ' '
    text: "\uFF08\u7B49\u4E00\u4E0B\uFF0C\u7B56\u5212\u6848\u662F\u5C0F\u7EA2\u5728\u505A\u554A\uFF0C\u53EB\u6211\u5E72\u561B\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\uFF08\u54CE\uFF0C\u53BB\u6700\u5DE6\u8FB9\u7684\u6587\u4EF6\u67DC\u62FF\u7B56\u5212\u6848\u4EA4\u7ED9\u5C0F\u7EA2\uFF0C\u8BA9\u5979\u7ED9\u8001\u677F\u5F97\u4E86\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
