  interactKey: 101
  npcDialogue:
  - name: ' '
    text: "\u5F20\u603B\u76D1\u4E5F\u6CA1\u4E0B\u73ED\u5462\uFF1F"
    characterSprite: {fileID: 21300000, guid: 702b780de76d7154a90b6aac586fe3e3, type: 3}
  - name: ' '
    text: "\u5BF9\u554A\uFF0C\u4E00\u5230\u8FD9\u4E2A\u65F6\u5019\u5C31\u5FD9\u5F97\u4E0D\u884C\u3002"
    characterSprite: {fileID: 21300000, guid: 024539aa5c43ab246991ab9f75d0f485, type: 3}
  - name: ' '
    text: "\u60F3\u5FC5\u4F60\u4E5F\u5DF2\u7ECF\u4E60\u60EF\u4E86\u5427\u3002"
    characterSprite: {fileID: 21300000, guid: 024539aa5c43ab246991ab9f75d0f485, type: 3}
  - name: ' '
    text: "\uFF08\u8C22\u9080\uFF0C\u6839\u672C\u6CA1\u4E60\u60EF\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\u5DEE\u4E0D\u591A\u5427\u2026\u2026\uFF08\u8D54\u7B11\uFF09"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\u542C\u8BF4\u4F60\u5F88\u7231\u559D\u5496\u5561\u554A\uFF1F"
    characterSprite: {fileID: 21300000, guid: 024539aa5c43ab246991ab9f75d0f485, type: 3}
  - name: ' '
    text: "\u6211\u8FD8\u6CA1\u559D\u8FC7\u4F60\u505A\u7684\u5496\u5561\u5462\u3002"
    characterSprite: {fileID: 21300000, guid: 024539aa5c43ab246991ab9f75d0f485, type: 3}
  - name: ' '
    text: "\u4EC0\u4E48\u65F6\u5019\u8BA9\u6211\u5C1D\u5C1D\u4F60\u7684\u624B\u827A\uFF1F"
    characterSprite: {fileID: 21300000, guid: 024539aa5c43ab246991ab9f75d0f485, type: 3}
  - name: ' '
    text: "\uFF08\u4F60\u8FD9\u610F\u601D\u4E0D\u5C31\u662F\u73B0\u5728\u5417\u2026\u2026\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\u60A8\u7B49\u7740\uFF0C\u6211\u73B0\u5728\u5C31\u53BB\u7ED9\u60A8\u505A\uFF01"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\uFF08\uFF1F\uFF01\u600E\u4E48\u611F\u89C9\u53C8\u53EF\u4EE5\u8D70\u66F4\u8FDC\u4E86\u2026\u2026\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  jumpToScene: 
  jumpOnce: 1
  unlockFlagPhase1: 
  extendRopeAmount: 4
  markAsGotReport: 0
  setFlagPhase1: 
  phase2Dialogue:
  - name: ' '
    text: "\u603B\u76D1\uFF0C\u5496\u5561\u505A\u597D\u4E86\uFF0C\u5C0F\u5FC3\u70EB"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\u55F5\uFF0C\u516C\u53F8\u7684\u5496\u5561\u662F\u5F88\u4E0D\u9519"
    characterSprite: {fileID: 21300000, guid: 024539aa5c43ab246991ab9f75d0f485, type: 3}
  - name: ' '
    text: "\u4F46\u662F\u6211\u90FD\u559D\u817B\u4E86\u554A\u2026\u2026"
    characterSprite: {fileID: 21300000, guid: 024539aa5c43ab246991ab9f75d0f485, type: 3}
  - name: ' '
    text: "\u542C\u8BF4\u4F60\u5BF9\u5496\u5561\u8C46\u633A\u6709\u7814\u7A76\uFF0C\u597D\u4E1C\u897F\u8FD8\u662F\u4E0D\u613F\u610F\u7ED9\u516C\u53F8\u7684\u5BB6\u4EBA\u4EEC\u5206\u4EAB\u5417\uFF1F"
    characterSprite: {fileID: 21300000, guid: 024539aa5c43ab246991ab9f75d0f485, type: 3}
  - name: ' '
    text: "\u554A\uFF01\u5F53\u7136\u4E0D\u662F\uFF0C\u6211\u8FD9\u5C31\u53BB\u7ED9\u60A8\u62FF"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\uFF08\u8FD9\u4E2A\u5F20**\u8FDE\u5458\u5DE5\u5496\u5561\u8C46\u90FD\u8981\u8D2A\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\uFF08\u8FD8\u5F97\u56DE\u5DE5\u4F4D\u65C1\u8FB9\u7684\u77EE\u67DC\u5B50\u9876\u53D6\u5496\u5561\u8C46\u518D\u56DE\u6765\u7ED9\u4ED6\u51B2\uFF0C\u80FD\u6EDA\u4E0D\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\uFF08\u67DC\u5B50\u8FD9\u4E48\u9AD8\uFF0C\u53EA\u80FD\u8DF3\u8D77\u6765\u62FF\u4E86\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  unlockFlagPhase2: GotReport
  extendRopePhase2: 0
  setFlagPhase2: CoffeeGiven
  phase3Dialogue:
  - name: ' '
    text: "\u5F20\u603B\u76D1\u60A8\u8BF7\uFF08\u8D54\u7B11\uFF09"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\u55F5\uFF0C\u4F60\u8FD8\u662F\u61C2\u4E8B\u54C8\uFF0C\u6709\u673A\u4F1A\u6211\u8DDF\u8001\u677F\u5EFA\u8BAE\u63D0\u62D4\u4F60\u4E00\u4E0B\u3002"
    characterSprite: {fileID: 21300000, guid: 024539aa5c43ab246991ab9f75d0f485, type: 3}
  - name: ' '
    text: "\u591A\u8C22\u5F20\u603B\u76D1\u4E86"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\uFF08\u6709\u4EBA\u4FE1\u5417\u3002\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\u90A3\u5F20\u603B\u76D1\uFF0C\u6CA1\u4EC0\u4E48\u4E8B\u7684\u8BDD\u6211\u5C31\u5148\u8D70\u4E86"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\u54CE\u7B49\u7B49\uFF01"
    characterSprite: {fileID: 21300000, guid: 024539aa5c43ab246991ab9f75d0f485, type: 3}
  - name: ' '
    text: "\uFF1F\u8BF7\u95EE\u8FD8\u6709\u4EC0\u4E48\u4E8B\u5417\uFF1F"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\uFF08\u5F20**\uFF0C\u4F60\u600E\u4E48\u8FD8\u6D3B\u7740\u554A\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\u8001\u677F\u5728\u697C\u4E0B\u4F1A\u8BAE\u5BA4\u5F00\u4F1A\u5462\uFF0C\u4F60\u5E2E\u6211\u53BB\u770B\u770B\u5F00\u5B8C\u4F1A\u6CA1\u6709\u5462\uFF1F"
    characterSprite: {fileID: 21300000, guid: 024539aa5c43ab246991ab9f75d0f485, type: 3}
  - name: ' '
    text: "\u987A\u4FBF\u56DE\u6765\u7ED9\u6211\u8BF4\u4E00\u58F0\u3002"
    characterSprite: {fileID: 21300000, guid: 024539aa5c43ab246991ab9f75d0f485, type: 3}
  - name: ' '
    text: "\u597D\u7684\uFF0C\u6211\u9A6C\u4E0A\u5C31\u53BB\u3002"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\uFF08\u7EF3\u5B50\u53C8\u53D8\u957F\u4E86\u3002\u662F\u4E0D\u662F\u975E\u5F97\u5B8C\u6210\u6240\u6709\u5DE5\u4F5C\u624D\u80FD\u56DE\u5BB6\uFF1F\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\uFF08\u53F3\u624B\u8FB9\u4E0B\u697C\u5C31\u884C\u7684\u4E8B\u975E\u5F97\u8BA9\u6211\u50CF\u6253\u6742\u7684\u4E00\u6837\u3002\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  unlockFlagPhase3: Tea1CheckDone
  extendRopePhase3: 4
  setFlagPhase3: 
  phase4Dialogue:
  - name: ' '
    text: "\u5F20\u603B\u76D1\uFF0C\u8001\u677F\u8FD8\u6CA1\u5F00\u59CB\u5F00\u4F1A\u5462"
    characterSprite: {fileID: 21300000, guid: 702b780de76d7154a90b6aac586fe3e3, type: 3}
  - name: ' '
    text: "\u884C\u5427\uFF0C\u8C22\u8C22\u4F60\u554A\uFF0C\u4E0B\u6B21\u518D\u6765\u7ED9\u6211\u51B2\u5496\u5561\u54E6\uFF1F"
    characterSprite: {fileID: 21300000, guid: 024539aa5c43ab246991ab9f75d0f485, type: 3}
  - name: ' '
    text: "\u597D"
    characterSprite: {fileID: 21300000, guid: 702b780de76d7154a90b6aac586fe3e3, type: 3}
  - name: ' '
    text: "\uFF08\u6EDA\uFF09"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
