--- !u!114 &111033245
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 111033243}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2ee3f1b5096147143be75c38b5e26615, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  interactKey: 101
  npcDialogue:
  - name: ' '
    text: "\uFF08\u62FF\u7740\u7B56\u5212\u6848\uFF0C\u8BD5\u63A2\u5730\u5F00\u53E3\uFF09"
    characterSprite: {fileID: 21300000, guid: 702b780de76d7154a90b6aac586fe3e3, type: 3}
  - name: ' '
    text: "\u5C0F\u7EA2\uFF0C\u7B56\u5212\u6848\u6211\u62FF\u8FC7\u6765\u4E86\uFF0C\u4F60\u770B\u2026\u2026"
    characterSprite: {fileID: 21300000, guid: 702b780de76d7154a90b6aac586fe3e3, type: 3}
  - name: ' '
    text: "\u554A\uFF0C\u4F60\u7EC8\u4E8E\u6765\u4E86\u3002\u592A\u597D\u4E86\uFF0C\u6551\u5927\u547D\u4E86\u3002"
    characterSprite: {fileID: 21300000, guid: 355c8d3ec245860468f7dc894d75ce07, type: 3}
  - name: ' '
    text: "\u2026\u2026\u4EC0\u4E48\u6551\u5927\u547D\uFF1F"
    characterSprite: {fileID: 21300000, guid: 702b780de76d7154a90b6aac586fe3e3, type: 3}
  - name: ' '
    text: "\u8FD9\u4E2A\u7B56\u5212\u6848\u561B\uFF0C\u8001\u677F\u521A\u624D\u53C8\u8BF4\u8981\u5927\u6539\uFF0C\u9700\u6C42\u5168\u53D8\u4E86\u3002"
    characterSprite: {fileID: 21300000, guid: 355c8d3ec245860468f7dc894d75ce07, type: 3}
  - name: ' '
    text: "\u4F60\u4E5F\u77E5\u9053\uFF0C\u6211\u4ECA\u5929\u624B\u91CC\u4E09\u4E2A\u9700\u6C42\u8BC4\u5BA1\uFF0C\u5916\u52A0\u5468\u62A5\u8FD8\u6CA1\u7F16\u2014\u2014\u4E0D\u662F\uFF0C\u8FD8\u6CA1\u5199\u3002"
    characterSprite: {fileID: 21300000, guid: 355c8d3ec245860468f7dc894d75ce07, type: 3}
  - name: ' '
    text: "\u4F60\u770B\u4F60\u53CD\u6B63\u4E5F\u88AB\u2026\u2026\u5443\uFF0C\u6682\u65F6\u56FA\u5B9A\u5728\u5DE5\u4F4D\u4E0A\u4E86\u3002"
    characterSprite: {fileID: 21300000, guid: 355c8d3ec245860468f7dc894d75ce07, type: 3}
  - name: ' '
    text: "\u54EA\u513F\u4E5F\u53BB\u4E0D\u4E86\uFF0C\u8FD9\u4E0D\u6B63\u597D\u9759\u4E0B\u5FC3\u6765\u6539\u6539\u5417\uFF1F"
    characterSprite: {fileID: 21300000, guid: 355c8d3ec245860468f7dc894d75ce07, type: 3}
  - name: ' '
    text: "\u2026\u2026\u6211\u600E\u4E48\u542C\u7740\u8FD9\u4E48\u4E0D\u5BF9\u52B2\u5462\u3002\u8FD9\u539F\u672C\u4E0D\u662F\u4F60\u8D1F\u8D23\u7684\u5417\uFF1F"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\u54CE\uFF0C\u540C\u4E8B\u4E4B\u95F4\u5206\u4EC0\u4E48\u4F60\u6211\u3002\u4F60\u5E2E\u6211\u6539\u4E00\u4E0B\u3002"
    characterSprite: {fileID: 21300000, guid: 355c8d3ec245860468f7dc894d75ce07, type: 3}
  - name: ' '
    text: "\u4E0B\u6B21\u6211\u88AB\u62F4\u4F4F\u7684\u65F6\u5019\uFF0C\u5C31\u6362\u6211\u6765\u6539\u3002\u8FD9\u53EB\u53EF\u6301\u7EED\u53D1\u5C55\u3002"
    characterSprite: {fileID: 21300000, guid: 355c8d3ec245860468f7dc894d75ce07, type: 3}
  - name: ' '
    text: "\u6211\u73B0\u5728\u7684\u201C\u53EF\u6301\u7EED\u201D\u53EA\u4F53\u73B0\u5728\u7EF3\u5B50\u7684\u6750\u8D28\u4E0A\u3002"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: " \u597D\u5427\uFF0C\u52C9\u5F3A\u5E2E\u4F60\u6539\u4E00\u4E0B\uFF0C\u8BB0\u5F97\u4E0B\u6B21\u4E5F\u8981\u5E2E\u6211"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\u592A\u8C22\u8C22\u4F60\u4E86\uFF01"
    characterSprite: {fileID: 21300000, guid: 355c8d3ec245860468f7dc894d75ce07, type: 3}
  - name: ' '
    text: "\uFF08\u51E0\u5341\u5206\u949F\u540E\uFF09\u597D\u4E86\uFF0C\u8FD9\u4E2A\u4F60\u5C31\u81EA\u5DF1\u4EA4\u53BB\u5427\uFF1F"
    characterSprite: {fileID: 21300000, guid: 666601e78604c7b4b83ee7cf75ff13cd, type: 3}
  - name: ' '
    text: "\u6211\u53EF\u4EE5\u56DE\u5BB6\u4E86\u5427\uFF1F"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\uFF08\u5408\u6210\u5927\u5DE5\u4F4D\u4E2D\u2026\u2026\uFF09\u55EF\u55EF\u3002"
    characterSprite: {fileID: 21300000, guid: 355c8d3ec245860468f7dc894d75ce07, type: 3}
  - name: ' '
    text: "\u62DC\u62DC\u54AF\uFF0C\u5E26\u5584\u4EBA\uFF01"
    characterSprite: {fileID: 21300000, guid: 355c8d3ec245860468f7dc894d75ce07, type: 3}
  - name: ' '
    text: "\uFF08\u597D\u50CF\u53C8\u53EF\u4EE5\u8D70\u8FDC\u4E00\u70B9\u4E86\uFF09"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\uFF08\u6211\u7684\u8C6A\u65AF\u6211\u83B1\u7EB3\uFF01\uFF09"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
