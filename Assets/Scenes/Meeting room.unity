  interactKey: 101
  npcDialogue:
  - name: ' '
    text: "\u8001\u677F\uFF0C\u8BF7\u95EE\u60A8\u5F00\u5B8C\u4F1A\u4E86\u5417\uFF1F"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\u4F60\u8FD9\u4E2A\u5C0F\u4F19\u600E\u4E48\u8FDB\u7684\u516C\u53F8\uFF0C\u770B\u4E0D\u51FA\u6765\u6211\u4E00\u4E2A\u4EBA\u5728\u8FD9\u91CC\u5750\u7740\u5417\uFF1F"
    characterSprite: {fileID: 21300000, guid: 114df3a1eb85b0c4b8c083016fadbfe5, type: 3}
  - name: ' '
    text: "\u2026\u2026"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\u6211\u8BA9\u4F60\u7ED9\u6211\u5E26\u7684\u7B56\u5212\u6848\u5462?"
    characterSprite: {fileID: 21300000, guid: 114df3a1eb85b0c4b8c083016fadbfe5, type: 3}
  - name: ' '
    text: "\u4F60\u77E5\u4E0D\u77E5\u9053\u56E0\u4E3A\u4F60\u7684\u539F\u56E0\uFF0C\u4F1A\u8BAE\u73B0\u5728\u90FD\u5F00\u4E0D\u4E86\u4E86\uFF01"
    characterSprite: {fileID: 21300000, guid: 114df3a1eb85b0c4b8c083016fadbfe5, type: 3}
  - name: ' '
    text: "\u6211\u9A6C\u4E0A\u7ED9\u60A8\u62FF\u53BB\uFF01"
    characterSprite: {fileID: 21300000, guid: c233873247c1ae14b97dcac48c763e71, type: 3}
  - name: ' '
    text: "\uFF08\u6551\u547D\u5427!\u8FD8\u5F97\u56DE\u53BB\u627E\u5C0F\u7EA2\uFF0C\u987A\u4FBF\u544A\u8BC9\u5F20\u603B\u76D1\u8001\u677F\u8FD8\u6CA1\u5F00\u4F1A\u5462\uFF09"
